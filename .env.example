# Vercel / web
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
AUTH_SECRET=replace-with-a-long-random-value
ADMIN_USERNAME=admin
# Base64-encoded Argon2 hashes generated with `pnpm --filter @spp/web auth:hash -- "password"`
ADMIN_PASSWORD_HASH_BASE64=replace-with-auth-hash-output
CONTROLLER_PASSWORD_HASH_BASE64=replace-with-auth-hash-output

# Object storage: vercel-blob or s3
STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false

# MQTT server publisher and public read-only browser
MQTT_URL=mqtts://broker.example.com:8883
MQTT_TOPIC_PREFIX=pianos
MQTT_SERVER_USERNAME=vercel-publisher
MQTT_SERVER_PASSWORD=replace-me
NEXT_PUBLIC_MQTT_WS_URL=wss://broker.example.com:8084/mqtt
NEXT_PUBLIC_MQTT_BROWSER_USERNAME=browser-readonly
NEXT_PUBLIC_MQTT_BROWSER_PASSWORD=replace-me

# One-time database bootstrap and simulator
PIANO_DEVICE_TOKEN=replace-with-a-long-random-value
PIANO_NAME=House Piano
PIANO_SLUG=house-piano
PIANO_ID=00000000-0000-0000-0000-000000000000
API_BASE_URL=http://localhost:3000
MQTT_DEVICE_USERNAME=piano-device
MQTT_DEVICE_PASSWORD=replace-me
